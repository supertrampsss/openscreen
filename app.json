{
	"expo": {
		"name": "Crohnicle",
		"slug": "crohnicle",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "crohnicle",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"icon": "./assets/expo.icon"
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#E6F4FE",
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"predictiveBackGestureEnabled": false
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"backgroundColor": "#208AEF",
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 76
				}
			],
			[
				"expo-image-picker",
				{
					"photosPermission": "Crohnicle utilise vos photos pour analyser vos repas.",
					"cameraPermission": "Crohnicle utilise l'appareil photo pour analyser vos repas."
				}
			],
			"expo-notifications",
			"expo-quick-actions"
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		}
	}
}

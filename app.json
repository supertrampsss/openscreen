{
	"expo": {
		"name": "Crohnicle",
		"slug": "crohnicle",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "crohnicle",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"icon": "./assets/images/icon.png",
			"bundleIdentifier": "app.crohnicle",
			"buildNumber": "1",
			"privacyManifests": {
				"NSPrivacyTracking": false,
				"NSPrivacyAccessedAPITypes": [
					{
						"NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
						"NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
					},
					{
						"NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
						"NSPrivacyAccessedAPITypeReasons": ["C617.1"]
					},
					{
						"NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
						"NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
					},
					{
						"NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
						"NSPrivacyAccessedAPITypeReasons": ["E174.1"]
					}
				],
				"NSPrivacyCollectedDataTypes": [
					{
						"NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypePhotosorVideos",
						"NSPrivacyCollectedDataTypeLinked": false,
						"NSPrivacyCollectedDataTypeTracking": false,
						"NSPrivacyCollectedDataTypePurposes": [
							"NSPrivacyCollectedDataTypePurposeAppFunctionality"
						]
					},
					{
						"NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeDeviceID",
						"NSPrivacyCollectedDataTypeLinked": false,
						"NSPrivacyCollectedDataTypeTracking": false,
						"NSPrivacyCollectedDataTypePurposes": [
							"NSPrivacyCollectedDataTypePurposeAppFunctionality"
						]
					},
					{
						"NSPrivacyCollectedDataType": "NSPrivacyCollectedDataTypeHealth",
						"NSPrivacyCollectedDataTypeLinked": false,
						"NSPrivacyCollectedDataTypeTracking": false,
						"NSPrivacyCollectedDataTypePurposes": [
							"NSPrivacyCollectedDataTypePurposeAppFunctionality"
						]
					}
				]
			}
		},
		"android": {
			"package": "app.crohnicle",
			"versionCode": 1,
			"adaptiveIcon": {
				"backgroundColor": "#F7F7F8",
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"predictiveBackGestureEnabled": false
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"backgroundColor": "#F7F7F8",
					"dark": { "backgroundColor": "#0A0A0A" },
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 160
				}
			],
			[
				"expo-image-picker",
				{
					"photosPermission": "Crohnicle utilise vos photos pour analyser vos repas. Les photos de repas sont envoyées à notre service d'analyse par IA (Anthropic Claude) et ne sont pas conservées.",
					"cameraPermission": "Crohnicle utilise l'appareil photo pour analyser vos repas. Les photos de repas sont envoyées à notre service d'analyse par IA (Anthropic Claude) et ne sont pas conservées."
				}
			],
			"expo-notifications",
			"expo-quick-actions",
			[
				"expo-location",
				{
					"locationWhenInUsePermission": "Crohnicle utilise votre position, uniquement à votre demande, pour trouver les toilettes à proximité. Rien n'est stocké."
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		}
	}
}

{
	"expo": {
		"name": "Crohnicle",
		"slug": "crohnicle",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "crohnicle",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"icon": "./assets/images/icon.png"
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#F7F7F8",
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"predictiveBackGestureEnabled": false
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-splash-screen",
				{
					"backgroundColor": "#F7F7F8",
					"dark": { "backgroundColor": "#0A0A0A" },
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 160
				}
			],
			[
				"expo-image-picker",
				{
					"photosPermission": "Crohnicle utilise vos photos pour analyser vos repas : vos photos de repas sont envoyées à notre service d'analyse et ne sont pas conservées.",
					"cameraPermission": "Crohnicle utilise l'appareil photo pour analyser vos repas : vos photos de repas sont envoyées à notre service d'analyse et ne sont pas conservées."
				}
			],
			"expo-notifications",
			"expo-quick-actions",
			[
				"expo-location",
				{
					"locationWhenInUsePermission": "Crohnicle utilise votre position, uniquement à votre demande, pour trouver les toilettes à proximité. Rien n'est stocké."
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		}
	}
}

{
	"name": "crohnicle",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"private": true,
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"start": "expo start",
		"android": "expo start --android",
		"ios": "expo start --ios",
		"web": "expo start --web",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"i18n:check": "node scripts/i18n-check.mjs",
		"build:web": "expo export --platform web",
		"postinstall": "patch-package",
		"prepare": "husky || true"
	},
	"dependencies": {
		"@expo/ui": "~57.0.3",
		"drizzle-orm": "^0.45.2",
		"expo": "~57.0.2",
		"expo-constants": "~57.0.3",
		"expo-device": "~57.0.0",
		"expo-document-picker": "~57.0.0",
		"expo-file-system": "~57.0.0",
		"expo-font": "~57.0.0",
		"expo-glass-effect": "~57.0.0",
		"expo-image": "~57.0.0",
		"expo-linking": "~57.0.1",
		"expo-localization": "~57.0.0",
		"expo-router": "~57.0.3",
		"expo-sharing": "~57.0.2",
		"expo-splash-screen": "~57.0.2",
		"expo-sqlite": "~57.0.0",
		"expo-status-bar": "~57.0.0",
		"expo-symbols": "~57.0.0",
		"expo-system-ui": "~57.0.0",
		"expo-web-browser": "~57.0.0",
		"i18next": "^26.3.4",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-i18next": "^17.0.8",
		"react-native": "0.86.0",
		"react-native-gesture-handler": "~2.32.0",
		"react-native-reanimated": "4.5.0",
		"react-native-safe-area-context": "~5.7.0",
		"react-native-screens": "4.25.2",
		"react-native-svg": "^15.15.4",
		"react-native-web": "~0.21.0",
		"react-native-worklets": "0.10.0",
		"uuid": "^14.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.13",
		"@playwright/test": "^1.58.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/react": "~19.2.2",
		"@types/uuid": "^10.0.0",
		"babel-plugin-inline-import": "^3.0.0",
		"better-sqlite3": "^12.11.1",
		"drizzle-kit": "^0.31.10",
		"fast-check": "^4.5.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"patch-package": "^8.0.1",
		"typescript": "~6.0.3",
		"vitest": "^4.0.16"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,mts,cts,json}": "biome check --no-errors-on-unmatched"
	}
}

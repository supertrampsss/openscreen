{
	"cli": {
		"version": ">= 12.0.0",
		"appVersionSource": "remote"
	},
	"build": {
		"development": {
			"developmentClient": true,
			"distribution": "internal",
			"channel": "development",
			"env": {
				"EXPO_PUBLIC_ENTITLEMENTS": "mock"
			},
			"ios": { "simulator": true }
		},
		"preview": {
			"distribution": "internal",
			"channel": "preview",
			"env": {
				"EXPO_PUBLIC_ENTITLEMENTS": "mock"
			}
		},
		"production": {
			"autoIncrement": true,
			"channel": "production",
			"env": {
				"EXPO_PUBLIC_ENTITLEMENTS": "mock"
			}
		}
	},
	"submit": {
		"production": {}
	}
}
